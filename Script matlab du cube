clc;
clear;
close all;
L=10
B=10
h=10
vertices=[
    0 0 0;  %1
    L 0 0;  %2
    L B 0;  %3
    0 B 0;  %4
    0 0 h;  %5
    L 0 h;  %6
    L B h;  %7
    0 B h;  %8
    ] ;
faces=[
    1 2 3 4;  %1
    5 6 7 8;  %2
    1 2 6 5;  %3
    2 3 7 6;  %4
    3 4 8 7;  %5
    4 1 5 8;  %6
    ];

figure;

patch( 'Vertices', vertices, 'Faces',faces,'Facecolor','red','Edgecolor','b');
xlabel( 'axe x');
ylabel( 'axe y');
zlabel( 'axe z');
title('mon_cube_3d');
axis equal;
